{
  "name": "welsh-sm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Predicate over (Lexeme, Environment): does this token exhibit Welsh soft mutation?",
  "bin": {
    "welsh-sm": "bin/welsh-sm.ts"
  },
  "scripts": {
    "cli": "tsx bin/welsh-sm.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "ud:fetch": "curl -sL --create-dirs -o data/ud/cy_ccg-ud-train.conllu https://raw.githubusercontent.com/UniversalDependencies/UD_Welsh-CCG/r2.18/cy_ccg-ud-train.conllu -o data/ud/cy_ccg-ud-dev.conllu https://raw.githubusercontent.com/UniversalDependencies/UD_Welsh-CCG/r2.18/cy_ccg-ud-dev.conllu -o data/ud/cy_ccg-ud-test.conllu https://raw.githubusercontent.com/UniversalDependencies/UD_Welsh-CCG/r2.18/cy_ccg-ud-test.conllu",
    "ud:extract": "tsx pipeline/extract-lexicon.ts",
    "apertium:fetch": "curl -sL --create-dirs -o data/apertium/apertium-cym.cym.dix https://raw.githubusercontent.com/apertium/apertium-cym/caf86f271d47e8f7368d67758e270de26ee25a05/apertium-cym.cym.dix",
    "apertium:extract": "tsx pipeline/extract-apertium.ts",
    "coverage": "tsx pipeline/coverage.ts",
    "chunker:spans": "tsx pipeline/spancheck.ts",
    "report": "tsx report/report.ts",
    "report:pdf": "npm run report && pandoc REPORT.md -o REPORT.pdf --pdf-engine=/Library/TeX/texbin/lualatex --shift-heading-level-by=-1 --toc --toc-depth=1 -V mainfont='STIX Two Text' -V mainfontfallback='STIX Two Math:' -V monofont=Menlo -V monofontoptions=Scale=0.85 -V geometry:margin=2.5cm -V fontsize=11pt -V colorlinks=true -M date='July 2026'"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
